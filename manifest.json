{
  "manifest_version": 3,
  "name": "D&amp;Z GM Tool",
  "version": "1.1.0",
  "description": "Initiative tracker, action economy, weapon resolvers, and walker bestiary for D&amp;Z RPG. Now with Owlbear Rodeo integration!",
  "author": "Self-hosted",
  
  "icons": {
    "16": "icon.svg",
    "32": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  },
  
  "permissions": [
    "storage",
    "activeTab",
    "sidePanel"
  ],
  
  "host_permissions": [
    "https://*.owlbear.fyi/*"
  ],
  
  "action": {
    "default_popup": "dz-gm-tool.html",
    "default_title": "D&amp;Z GM Tool"
  },
  
  "side_panel": {
    "default_path": "dz-gm-tool.html"
  },
  
  "content_scripts": [
    {
      "matches": ["https://*.owlbear.fyi/*"],
      "js": ["dz-gm-tool.html"],
      "css": [],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  
  "background": {
    "service_worker": "background.js"
  },
  
  "web_accessible_resources": [
    {
      "resources": ["dz-gm-tool.html", "icon.svg"],
      "matches": ["https://*.owlbear.fyi/*"]
    }
  ]
}

